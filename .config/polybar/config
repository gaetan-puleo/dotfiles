[colors]
primary = #45ADA8
secondary = #9DE0AD
danger = #EF3D59
alert = #EFC958
success = #4AB19D

dark = #222
darker = #111

light = #ccc
lighter = #eee
background = #ff222831
foreground = #eee
white = #fff
theme = #ff0000

[bar/barminimal]
width = 100%
height = 28
fixed-center = true
underline-size = 2
background = ${colors.background}
foreground = ${colors.foreground}


border-size = 0
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0

font-0 = "Noto Sans:pixelsize=10;2"
font-1 = "DroidSansMono Nerd Font:size=12;2"

modules-left =  i3
modules-center = 
modules-right = xkeyboard vpn pulseaudio date wlan battery 

tray-position = right

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = %title:0:20:...%
label-background = ${colors.darker}
label-padding = 3

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
format-padding = 2
label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
format-padding = 0
index-sort = true
wrapping-scroll = false
label-mode-padding = 3
label-foreground = ${colors.foreground}
label-mode-foreground = ${colors.alert}
label-mode-underline = ${colors.alert}
label-focused = %name%
label-focused-padding = 3
label-focused-foreground = ${colors.white}
label-focused-underline = ${colors.white}
label-unfocused = %name%
label-unfocused-padding = 3
label-unfocused-foreground = ${colors.light}

label-visible = %name%
label-visible-padding = ${self.label-focused-padding}

label-urgent = %name%
label-urgent-padding = 3
label-urgent-underline = ${colors.danger}


[module/wlan]
type = internal/network
interface = ${env:WLAN_INTERFACE:wlp2s0}
interval = 1
format-connected = Ô™®
format-connected-padding = 2
label-connected = %{A1:nm-connection-editor:}%essid%%{A}

format-disconnected = Ô™©
format-disconnected-padding = 2

[module/eth]
type = internal/network
interface = docker0
interval = 3.0

label-connected = %local_ip%

format-disconnected = LAN disabled

[module/date]
type = internal/date
interval = 1

time =  "%H:%M"
time-alt = "Ôó¨ %d-%m-%Y %H:%M"

label = %date% %time%
label-padding = 2

[module/pulseaudio]
type = internal/pulseaudio


format-volume = <label-volume>
format-volume-padding = 2
label-volume = %{A1:pavucontrol:}ÔÄ® %percentage%%%{A}

format-muted = <label-muted>
format-muted-padding = 2
label-muted = %{A1:pavucontrol:}ÔĎ¶ %{A}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98
format-full = ÔČÄ <label-full>
format-full-padding = 2
format-charging = <animation-charging> <label-charging>
format-charging-padding = 2

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-padding = 2

ramp-capacity-0 = ÔēĻ
ramp-capacity-0-foreground = ${colors.danger}
ramp-capacity-1-foreground = ${colors.danger}
ramp-capacity-1 = Ôēļ
ramp-capacity-2 = ÔēĽ
ramp-capacity-3 = Ôēľ
ramp-capacity-4 = ÔēĹ
ramp-capacity-5 = Ôēĺ
ramp-capacity-6 = ÔēŅ
ramp-capacity-7 = ÔēŅ
ramp-capacity-8 = ÔĖĀ
ramp-capacity-9 = Ôēł

animation-charging-0 = ÔĖÖ
animation-charging-1 = ÔĖÜ
animation-charging-2 = ÔĖá
animation-charging-3 = ÔĖą
animation-charging-4 = ÔĖČ
animation-charging-5 = ÔĖä
animation-charging-6 = ÔĖĄ
animation-charging-framerate = 750

[module/vpn]
type = custom/script
exec = zsh  ~/.config/polybar/vpn.sh
format-padding = 2
interval = 5
format-font = 2

[global/wm]
margin-top = 0
margin-bottom = 0


