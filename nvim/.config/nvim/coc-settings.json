{
  // tsserver
  "javascript.suggest.enabled": false,
  "javascript.validate.enable": false,
  // snippets
  "snippets.ultisnips.directories": [
    "UltiSnips",
    "~/.config/nvim/utilsnips"
  ],
  // emmet
  "emmet.includeLanguages": { "javascript": "javascriptreact"},
  // eslint
  "eslint.enable": true,
  "eslint.autoFixOnSave": true,
  "eslint.filetypes": ["javascript", "typescript", "typescriptreact", "javascriptreact", "typescript.tsx"],
  //prettier
  "coc.preferences.formatOnSaveFiletypes": ["css","scss","javascript", "typescript", "typescriptreact", "json", "javascriptreact", "typescript.tsx"],
  // diagnostic
  "diagnostic.errorSign": "•",
  "diagnostic.warningSign": "•",
  "diagnostic.infoSign": "•",
  // json
}
