# i3 config file (v4)
# Please see http://i3wm.org/docs/userguide.html for a complete reference!

#
# VARIABLES
#

# keys
# Set mod key (Mod1=<Alt>, Mod4=<Super>)
set $win Mod4
set $mod Mod4
set $alt Mod1
set $ctrl Control

# terminal
set $term kitty
# set default desktop layout (default is tiling)

# change container layout (stacked, tabbed, toggle split)
# bindsym $mod+s layout toggle split
# bindsym $mod+t layout tabbed

# split orientation
bindsym $mod+s split h;exec --no-startup-id notify-send 'tile horizontally'
bindsym $mod+v split v;exec --no-startup-id notify-send 'tile vertically'

# Configure border style <normal|1pixel|pixel xx|none|pixel>
new_window pixel 1
new_float normal

# Hide borders
hide_edge_borders smart

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
# set font
font pango: Noto Sans 11

# Use Mouse+$mod to drag floating windows
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec --no-startup-id $term

# kill focused window
bindsym $mod+q kill
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% #increase sound volume
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% #decrease sound volume
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle # mute sound
# start program launcher
bindsym $mod+d exec --no-startup-id rofi -show drun

# Start Applications
bindsym Print exec --no-startup-id i3-scrot
bindsym $mod+Print --release exec --no-startup-id i3-scrot -w
bindsym $mod+Shift+Print --release exec --no-startup-id i3-scrot -s
bindsym $mod+Ctrl+x --release exec --no-startup-id xkill

focus_follows_mouse no

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right 
bindsym $mod+semicolon focus right

set $MoveSplit Move split
bindsym $mod+Shift+m mode "$MoveSplit"
mode "$MoveSplit" {

    # exit resize mode: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"

    # alternatively, you can use the cursor keys:
    bindsym h move left
    bindsym j move down
    bindsym k move up
    bindsym l move right
}

# workspace back and forth (with/without active container)
workspace_auto_back_and_forth yes

# toggle fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

#navigate workspaces next / previous
bindsym $mod+Shift+l workspace next
bindsym $mod+Shift+h workspace prev

# bindsym $mod+B exec --no-startup-id pkill polybar && polybar barminimal
# Workspace names
set $ws1 1: 
set $ws2 2: 
set $ws3 3: 
set $ws4 4: 
set $ws5 5: 
set $ws6 6: 
set $ws7 7: 
set $ws8 8: 
set $ws9 9: 

# switch to workspace
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9

set $Move Move container to (1) (2) (3) (4) (5) (6) (7) (8) (9)
bindsym $mod+m mode "$Move"
mode "$Move" {
    # Move to workspace with focused container
    bindsym 1 move container to workspace $ws1; workspace $ws1
    bindsym 2 move container to workspace $ws2; workspace $ws2
    bindsym 3 move container to workspace $ws3; workspace $ws3
    bindsym 4 move container to workspace $ws4; workspace $ws4
    bindsym 5 move container to workspace $ws5; workspace $ws5
    bindsym 6 move container to workspace $ws6; workspace $ws6
    bindsym 7 move container to workspace $ws7; workspace $ws7
    bindsym 8 move container to workspace $ws8; workspace $ws8
    bindsym 9 move container to workspace $ws9; workspace $ws9

    # exit resize mode: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Open applications on specific workspaces
assign [class="firefox"] $ws3
assign [class="Firefox"] $ws3
assign [class="Chromium-browser"] $ws3
assign [class="chromium-browser"] $ws3

# Open specific applications in floating mode
for_window [class="(?i)virtualbox"] floating enable border normal

# switch to workspace with urgent window automatically
for_window [urgent=latest] focus

# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# Resize window (you can also use the mouse for that)
bindsym $mod+r mode "resize"
mode "resize" {
        # same bindings, but for the arrow keys
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        # exit resize mode: Enter or Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

# exit i3 (logs you out of your X session)
set $Lang Language (1) QWERTY US altgr-intl, (2) QWERTY US altgr-intl for mac (3) AZERTY FR
mode "$Lang" {
    bindsym 3 exec  --no-startup-id "setxkbmap -layout fr -variant"
    bindsym 2 exec  --no-startup-id "setxkbmap -layout us -variant altgr-intl -option altwin:swap_lalt_lwin"
    bindsym 1 exec  --no-startup-id "setxkbmap -layout us -variant altgr-intl"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+a mode "$Lang"

# exit i3 (logs you out of your X session)
set $System System (l) logout, (x) lock, (s) suspend, (r) reboot, (Shift+s) shutdown
mode "$System" {
    bindsym l exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym x exec --no-startup-id $HOME/.config/i3/scripts/i3lock.sh , mode "default"
    bindsym r exec --no-startup-id reboot, mode "default"
    bindsym Shift+s exec --no-startup-id shutdown now, mode "default" 

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+q mode "$System"

# Autostart applications
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id compton -b -f
exec --no-startup-id nm-applet
exec --no-startup-id xfce4-power-manager
exec --no-startup-id blueman-applet

exec_always --no-startup-id setxkbmap -option caps:super
exec_always --no-startup-id  zsh $HOME/.config/polybar/launch.sh
exec_always --no-startup-id feh --bg-scale ~/wallpaper.jpg

# Theme colors
# class                   border  backgr. text    indic.   child_border

  client.focused          #285577 #556064 #80FFF9 #FDF6E3
  client.focused_inactive #2F3D44 #2F3D44 #1ABC9C #454948
  client.unfocused        #2F3D44 #2F3D44 #1ABC9C #454948
  client.urgent           #CB4B16 #FDF6E3 #1ABC9C #268BD2
  client.placeholder      #000000 #0c0c0c #ffffff #000000 
  client.background       #2B2C2B
