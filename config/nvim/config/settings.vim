" true colors for terms
set termguicolors

" apply theme
colorscheme palenight

" One tab equal 2 spaces
set tabstop=2 shiftwidth=2 expandtab

" no alerts
set belloff=all

" show linenumber
set number

" leader key
let mapleader = ","

" allow clipboard
set clipboard+=unnamedplus

" choose split location
set splitbelow
set splitright

" Enable cursor line position tracking
set cursorline
