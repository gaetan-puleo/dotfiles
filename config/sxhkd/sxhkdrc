super + Return
        kitty

# application launcher
super + d
  rofi -show drun

# volume +
XF86AudioRaiseVolume
  pactl set-sink-volume @DEFAULT_SINK@ +5% && notify-send -t 1000 "Volume +5%" #increase sound volume
  # pactl set-sink-volume @DEFAULT_SINK@ +5% && notify-send -t 1000 "Volume + $(amixer get Master | grep -Eo '[0-9]+%')" #increase sound volume

# volume -
XF86AudioLowerVolume 
  pactl set-sink-volume @DEFAULT_SINK@ -5% && notify-send -t 1000 "Volume -5%" #decrease sound volume  
  # pactl set-sink-volume @DEFAULT_SINK@ -5% && notify-send -t 1000 "Volume - $(amixer get Master | grep -Eo '[0-9]+%')" #decrease sound volume

# volume mute
XF86AudioMute 
  pactl set-sink-mute @DEFAULT_SINK@ toggle && notify-send -t 1000 "Toggle Mute volume" # mute sound

# Print screen
# Without the sleep scrot crashes with:
# giblib error: couldn't grab keyboard:Resource temporarily unavailable
Print
    sleep 0.2; \
    scrot -s ~/'Pictures/%Y-%m-%d_%H%M%S-$wx$h_scrot.png'

control + Print
    scrot ~/'Pictures/%Y-%m-%d_%H%M%S-$wx$h_scrot.png'

